{
  "name": "inhouserx",
  "private": true,
  "version": "0.2.0",
  "description": "Privacy-first medical study coverage analysis with optional local OCR and media transcription.",
  "author": {
    "name": "Abinav Katuru",
    "email": "AKaturu@users.noreply.github.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AKaturu/InHouseRx.git"
  },
  "homepage": "https://github.com/AKaturu/InHouseRx#readme",
  "desktopName": "com.akaturu.inhouserx.desktop",
  "type": "module",
  "main": "electron/main.mjs",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k -s first \"vite --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "companion": "python companion/server.py",
    "build": "tsc -b && vite build",
    "icons": "node scripts/generate-icons.mjs",
    "desktop:dir": "pnpm build && electron-builder --dir",
    "desktop:win": "pnpm build && electron-builder --win --x64 --publish never",
    "desktop:mac": "pnpm build && electron-builder --mac --universal --publish never",
    "desktop:linux": "pnpm build && electron-builder --linux --x64 --publish never",
    "lint": "eslint .",
    "test": "vitest run",
    "test:desktop": "node --test electron/*.test.mjs",
    "test:companion": "python -m unittest companion.test_config",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^1.25.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "sharp": "0.35.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wait-on": "9.1.0"
  }
}
